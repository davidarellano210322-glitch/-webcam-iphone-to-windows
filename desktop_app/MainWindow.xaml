<Window x:Class="desktop_app.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NeoCamo Studio" Height="900" Width="1440"
        MinHeight="680" MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="{StaticResource BgBrush}" Foreground="{StaticResource OnSurfaceBrush}"
        FontFamily="{StaticResource DefaultFont}">

    <Window.Resources>
        <!-- Style for Section Card Containers -->
        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceLowBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource White10Brush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- Style for Scene Thumbnails -->
        <Style x:Key="SceneCardStyle" TargetType="Border">
            <Setter Property="Width" Value="108"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource White10Brush}"/>
            <Setter Property="Background" Value="{StaticResource SurfaceHighestBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="38"/>
            <RowDefinition Height="46"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- ROW 0: WINDOW TITLEBAR (WITH MINIMIZE, MAXIMIZE & CLOSE X BUTTONS) -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#F5121214" BorderBrush="{StaticResource White10Brush}" BorderThickness="0,0,0,1" MouseLeftButtonDown="TitleBar_MouseDown">
            <Grid>
                <!-- Title & Icon (Draggable) -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                    <Border Width="20" Height="20" CornerRadius="5" Background="#2055EE71" Margin="0,0,8,0">
                        <TextBlock Text="📹" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="NeoCamo Studio" FontFamily="{StaticResource HankenGrotesk}" FontSize="13" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text=" — Monitor Profesional USB" FontSize="11" Foreground="{StaticResource OnSurfaceVariantBrush}" VerticalAlignment="Center" Margin="6,0,0,0"/>
                </StackPanel>

                <!-- Window Control Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Stretch">
                    <Button x:Name="MinimizeBtn" Style="{StaticResource WindowControlButton}" Click="MinimizeBtn_Click" ToolTip="Minimizar">
                        <TextBlock Text="🗕" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                    </Button>
                    <Button x:Name="MaximizeBtn" Style="{StaticResource WindowControlButton}" Click="MaximizeBtn_Click" ToolTip="Maximizar">
                        <TextBlock x:Name="MaximizeIconText" Text="🗖" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                    </Button>
                    <Button x:Name="CloseBtn" Style="{StaticResource CloseWindowControlButton}" Click="CloseBtn_Click" ToolTip="Cerrar (✕)">
                        <TextBlock Text="✕" FontFamily="Segoe UI" FontSize="12" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- ROW 1: HEADER & STUDIO NAVIGATION BAR -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="#E6161618" BorderBrush="{StaticResource White10Brush}" BorderThickness="0,0,0,1">
            <Grid Margin="14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Branding & Tabs -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#1A55EE71" CornerRadius="10" Padding="10,3" Margin="0,0,8,0" VerticalAlignment="Center">
                        <TextBlock Text="Studio" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}"/>
                    </Border>
                    <TextBlock Text="Dashboard" FontSize="11" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,0,16,0" VerticalAlignment="Center" Cursor="Hand"/>
                    <TextBlock Text="Library" FontSize="11" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,0,16,0" VerticalAlignment="Center" Cursor="Hand"/>
                </StackPanel>

                <!-- Top Right Actions & Connection Status -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="RecordBtn" Style="{StaticResource DangerButton}" Click="RecordBtn_Click" Margin="0,0,8,0" Visibility="Collapsed" Height="28" Padding="12,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="●" FontSize="10" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="REC" FontFamily="{StaticResource GeistMono}" FontSize="10" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="StartTunnelBtn" Style="{StaticResource PrimaryButton}" Click="StartTunnelBtn_Click" Height="28" Padding="14,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="StartTunnelIcon" Text="▶" FontSize="9" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock x:Name="StartTunnelText" Text="INICIAR" FontFamily="{StaticResource GeistMono}" FontSize="10" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Border Background="{StaticResource SurfaceHighestBrush}" CornerRadius="12" Padding="10,3" Margin="10,0,0,0" VerticalAlignment="Center" BorderBrush="{StaticResource White10Brush}" BorderThickness="1">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse x:Name="StatusIndicatorDot" Width="6" Height="6" Fill="{StaticResource RedBrush}" Margin="0,0,5,0"/>
                            <TextBlock x:Name="StatusBadgeText" Text="SIN SEÑAL" FontFamily="{StaticResource GeistMono}" FontSize="9" FontWeight="Bold" Foreground="{StaticResource RedBrush}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- ROW 2: MAIN 3-COLUMN RESPONSIVE LAYOUT -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="285"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="290"/>
            </Grid.ColumnDefinitions>

            <!-- ─────────────────────────────────────────────────────────────── -->
            <!-- LEFT COLUMN: CONTROLS & CAMERA CONFIGURATION -->
            <!-- ─────────────────────────────────────────────────────────────── -->
            <Border Grid.Column="0" Background="{StaticResource SurfaceDimBrush}" BorderBrush="{StaticResource White10Brush}" BorderThickness="0,0,1,0">
                <ScrollViewer Padding="10,10,14,10" VerticalScrollBarVisibility="Auto" WindowChrome.IsHitTestVisibleInChrome="True">
                    <StackPanel>

                        <!-- Dispositivo -->
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <TextBlock Text="DISPOSITIVO" Style="{StaticResource MonoLabel}" Margin="0,0,0,6"/>
                                <Border Background="{StaticResource SurfaceHighBrush}" CornerRadius="6" Padding="8" BorderBrush="{StaticResource White10Brush}" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="📱" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock x:Name="DeviceComboBox" Text="Sin iPhone" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource OnSurfaceBrush}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock x:Name="DeviceDetailsText" Text="Desconectado" FontSize="10" Foreground="{StaticResource OnSurfaceVariantBrush}" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Lentes & Vista -->
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <TextBlock Text="LENTES Y VISTA" Style="{StaticResource MonoLabel}" Margin="0,0,0,6"/>

                                <!-- Lens selector pills -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <RadioButton x:Name="LensWide" Grid.Column="0" Content="0.5x" Style="{StaticResource ToggleRadioButton}" HorizontalAlignment="Stretch" Margin="0,0,2,0" Click="LensButton_Click" Tag="0.5x"/>
                                    <RadioButton x:Name="LensNormal" Grid.Column="1" Content="1x" Style="{StaticResource ToggleRadioButton}" HorizontalAlignment="Stretch" Margin="0,0,2,0" IsChecked="True" Click="LensButton_Click" Tag="1x"/>
                                    <RadioButton x:Name="LensTele" Grid.Column="2" Content="3x" Style="{StaticResource ToggleRadioButton}" HorizontalAlignment="Stretch" Click="LensButton_Click" Tag="3x"/>
                                </Grid>

                                <TextBlock Text="RESOLUCIÓN Y FPS" Style="{StaticResource MonoLabel}" Margin="0,0,0,4"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="70"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0" x:Name="ResolutionComboBox" SelectionChanged="ResolutionComboBox_SelectionChanged" HorizontalAlignment="Stretch">
                                        <ComboBoxItem Content="720p (HD)" Tag="720p"/>
                                        <ComboBoxItem Content="1080p (FHD)" Tag="1080p" IsSelected="True"/>
                                        <ComboBoxItem Content="4K (UHD)" Tag="4k"/>
                                    </ComboBox>
                                    <ComboBox Grid.Column="2" x:Name="FpsComboBox" SelectionChanged="ResolutionComboBox_SelectionChanged" HorizontalAlignment="Stretch">
                                        <ComboBoxItem Content="30 FPS" Tag="30" IsSelected="True"/>
                                        <ComboBoxItem Content="60 FPS" Tag="60"/>
                                    </ComboBox>
                                </Grid>

                                <Grid Margin="0,0,0,2">
                                    <TextBlock Text="ZOOM DIGITAL" Style="{StaticResource MonoLabel}"/>
                                    <TextBlock x:Name="ZoomValueText" Text="1.0x" FontFamily="{StaticResource GeistMono}" FontSize="10" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Right"/>
                                </Grid>
                                <Slider x:Name="ZoomSlider" Minimum="1.0" Maximum="5.0" Value="1.0" SmallChange="0.1" ValueChanged="ZoomSlider_ValueChanged"/>
                            </StackPanel>
                        </Border>

                        <!-- Exposición & Color -->
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <TextBlock Text="EXPOSICIÓN Y COLOR" Style="{StaticResource MonoLabel}" Margin="0,0,0,6"/>

                                <CheckBox x:Name="ExposureCheckBox" Content="Exposición Manual" Checked="ExposureControl_Changed" Unchecked="ExposureControl_Changed" Margin="0,0,0,6"/>

                                <TextBlock Text="Shutter (ms)" FontSize="10" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,0,0,1"/>
                                <Slider x:Name="ShutterSlider" Minimum="1" Maximum="200" Value="33" IsEnabled="False" Margin="0,0,0,4" ValueChanged="ExposureControl_Changed"/>

                                <Grid Margin="0,0,0,1">
                                    <TextBlock Text="ISO Gain" FontSize="10" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                                    <TextBlock x:Name="IsoValueText" Text="ISO: 300" FontFamily="{StaticResource GeistMono}" FontSize="10" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Right"/>
                                </Grid>
                                <Slider x:Name="IsoSlider" Minimum="50" Maximum="1600" Value="300" IsEnabled="False" Margin="0,0,0,8" ValueChanged="ExposureControl_Changed"/>

                                <Border Height="1" Background="{StaticResource White05Brush}" Margin="0,0,0,8"/>

                                <CheckBox x:Name="WhiteBalanceCheckBox" Content="Balance de Blancos Manual" Checked="WhiteBalanceControl_Changed" Unchecked="WhiteBalanceControl_Changed" Margin="0,0,0,6"/>

                                <Grid Margin="0,0,0,1">
                                    <TextBlock Text="Temperatura (K)" FontSize="10" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                                    <TextBlock x:Name="TempValueText" Text="5000K" FontFamily="{StaticResource GeistMono}" FontSize="10" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Right"/>
                                </Grid>
                                <Slider x:Name="TemperatureSlider" Minimum="2000" Maximum="8000" Value="5000" IsEnabled="False" Margin="0,0,0,4" ValueChanged="WhiteBalanceControl_Changed"/>

                                <TextBlock Text="Tint (Matiz)" FontSize="10" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,0,0,1"/>
                                <Slider x:Name="TintSlider" Minimum="-150" Maximum="150" Value="0" IsEnabled="False" Margin="0,0,0,8" ValueChanged="WhiteBalanceControl_Changed"/>

                                <Border Height="1" Background="{StaticResource White05Brush}" Margin="0,0,0,8"/>

                                <CheckBox x:Name="TorchCheckBox" Content="Linterna (Flash Torch)" Checked="TorchControl_Changed" Unchecked="TorchControl_Changed"/>
                            </StackPanel>
                        </Border>

                        <!-- Filtros & Efectos -->
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <TextBlock Text="FILTROS Y EFECTOS" Style="{StaticResource MonoLabel}" Margin="0,0,0,6"/>

                                <ComboBox x:Name="FilterComboBox" SelectionChanged="FilterComboBox_SelectionChanged" Margin="0,0,0,6" HorizontalAlignment="Stretch">
                                    <ComboBoxItem Content="Ninguno" Tag="none" IsSelected="True"/>
                                    <ComboBoxItem Content="Monocromo" Tag="mono"/>
                                    <ComboBoxItem Content="Sepia" Tag="sepia"/>
                                    <ComboBoxItem Content="Negativo" Tag="negative"/>
                                    <ComboBoxItem Content="Vintage" Tag="vintage"/>
                                    <ComboBoxItem Content="Cool Blue" Tag="cool"/>
                                </ComboBox>

                                <TextBlock Text="Intensidad de Filtro" FontSize="10" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,0,0,1"/>
                                <Slider x:Name="FilterIntensitySlider" Minimum="0" Maximum="100" Value="100" SmallChange="5" Margin="0,0,0,8" ValueChanged="FilterIntensitySlider_ValueChanged"/>

                                <Border Height="1" Background="{StaticResource White05Brush}" Margin="0,0,0,8"/>

                                <CheckBox x:Name="SpotlightCheckBox" Content="Spotlight (Foco Facial)" Checked="SpotlightCheckBox_Changed" Unchecked="SpotlightCheckBox_Changed" Margin="0,0,0,4"/>
                                <Slider x:Name="SpotlightSlider" Minimum="0" Maximum="100" Value="48" Margin="0,0,0,6" ValueChanged="SpotlightSlider_ValueChanged"/>

                                <CheckBox x:Name="AutoFramingCheckBox" Content="Auto Framing (Seguimiento)" Checked="AutoFramingControl_Changed" Unchecked="AutoFramingControl_Changed" Margin="0,0,0,4"/>
                                <CheckBox x:Name="AutoFramingZoomCheckBox" Content="Auto Zoom Dinámico" Checked="AutoFramingControl_Changed" Unchecked="AutoFramingControl_Changed" IsEnabled="False"/>
                            </StackPanel>
                        </Border>

                        <!-- Transformación -->
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <TextBlock Text="TRANSFORMACIÓN" Style="{StaticResource MonoLabel}" Margin="0,0,0,6"/>
                                <CheckBox x:Name="MirrorCheckBox" Content="Voltear Espejo" Checked="TransformControl_Changed" Unchecked="TransformControl_Changed" Margin="0,0,0,6"/>
                                <ComboBox x:Name="RotationComboBox" SelectionChanged="TransformControl_Changed" HorizontalAlignment="Stretch">
                                    <ComboBoxItem Content="Rotación: 0°" Tag="0" IsSelected="True"/>
                                    <ComboBoxItem Content="Rotación: 90°" Tag="90"/>
                                    <ComboBoxItem Content="Rotación: 180°" Tag="180"/>
                                    <ComboBoxItem Content="Rotación: 270°" Tag="270"/>
                                </ComboBox>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ─────────────────────────────────────────────────────────────── -->
            <!-- CENTER COLUMN: LIVE VIEWPORT + SCENE STRIP -->
            <!-- ─────────────────────────────────────────────────────────────── -->
            <Grid Grid.Column="1" Background="{StaticResource SurfaceLowestBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="86"/>
                </Grid.RowDefinitions>

                <!-- Sub-bar (Zoom Telemetry & Logs Toggle) -->
                <Border Grid.Row="0" Background="{StaticResource SurfaceLowBrush}" BorderBrush="{StaticResource White10Brush}" BorderThickness="0,0,0,1" Padding="10,0">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="ZOOM VISTA" Style="{StaticResource MonoLabel}" FontSize="9" Margin="0,0,4,0"/>
                            <TextBlock Text="100%" FontFamily="{StaticResource GeistMono}" FontSize="10" Foreground="{StaticResource PrimaryBrush}"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right" WindowChrome.IsHitTestVisibleInChrome="True">
                            <CheckBox x:Name="ShowLogsCheckBox" Content="Logs consola" FontSize="10" Foreground="{StaticResource OnSurfaceVariantBrush}" Checked="ShowLogsCheckBox_Changed" Unchecked="ShowLogsCheckBox_Changed" Margin="0,0,14,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="BatteryPercentageText" Text="100%" FontFamily="{StaticResource GeistMono}" FontSize="10" Foreground="{StaticResource OnSurfaceVariantBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock x:Name="BatteryIcon" Text="🔋" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Main Video Container -->
                <Grid Grid.Row="1" Margin="8">
                    <Grid.Background>
                        <VisualBrush TileMode="Tile" Viewport="0,0,24,24" ViewportUnits="Absolute">
                            <VisualBrush.Visual>
                                <Grid Width="24" Height="24">
                                    <Rectangle Fill="#08080A"/>
                                    <Ellipse Width="1.5" Height="1.5" Fill="#0DFFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </VisualBrush.Visual>
                        </VisualBrush>
                    </Grid.Background>

                    <!-- Preview Frame Border -->
                    <Border Background="#050507" CornerRadius="8" BorderBrush="{StaticResource White10Brush}" BorderThickness="1" ClipToBounds="True" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                        <Grid>
                            <!-- Live Image -->
                            <Image x:Name="VideoPreviewImage" Stretch="Uniform" RenderOptions.BitmapScalingMode="Linear" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                            <!-- Disconnected Placeholder -->
                            <Grid x:Name="PlaceholderGrid" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Border Width="56" Height="56" Background="{StaticResource SurfaceHighBrush}" CornerRadius="28" BorderBrush="{StaticResource White10Brush}" BorderThickness="1" Margin="0,0,0,10">
                                        <TextBlock Text="📹" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="NeoCamo Studio" FontSize="17" FontWeight="Bold" Foreground="{StaticResource OnSurfaceBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Conecta tu iPhone por USB y presiona INICIAR" FontSize="11" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>

                            <!-- Live Badge Top-Left -->
                            <Border x:Name="LiveBadge" Background="{StaticResource RedBrush}" CornerRadius="4" Padding="7,2" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10" Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="5" Height="5" Fill="White" Margin="0,0,5,0"/>
                                    <TextBlock Text="EN VIVO" FontFamily="{StaticResource GeistMono}" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                </StackPanel>
                            </Border>

                            <!-- Telemetry Bottom-Left -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="10">
                                <Border Background="#B3000000" CornerRadius="5" Padding="6,3" BorderBrush="{StaticResource White10Brush}" BorderThickness="1" Margin="0,0,6,0">
                                    <StackPanel>
                                        <TextBlock Text="TIEMPO" FontFamily="{StaticResource GeistMono}" FontSize="8" Foreground="#80FFFFFF"/>
                                        <TextBlock x:Name="RecTimeText" Text="00:00:00" FontFamily="{StaticResource GeistMono}" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#B3000000" CornerRadius="5" Padding="6,3" BorderBrush="{StaticResource White10Brush}" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="DISCO" FontFamily="{StaticResource GeistMono}" FontSize="8" Foreground="#80FFFFFF"/>
                                        <TextBlock Text="2.4 TB" FontFamily="{StaticResource GeistMono}" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Audio VU Meters Bottom-Right -->
                            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="10" Width="85">
                                <Border Height="3" Background="{StaticResource White10Brush}" CornerRadius="1.5" Margin="0,0,0,2">
                                    <Border x:Name="AudioBarLeftFill" Height="3" Background="{StaticResource PrimaryBrush}" CornerRadius="1.5" Width="50" HorizontalAlignment="Left"/>
                                </Border>
                                <Border Height="3" Background="{StaticResource White10Brush}" CornerRadius="1.5">
                                    <Border x:Name="AudioBarRightFill" Height="3" Background="{StaticResource PrimaryBrush}" CornerRadius="1.5" Width="35" HorizontalAlignment="Left"/>
                                </Border>
                            </StackPanel>

                            <!-- Log Console Overlay -->
                            <Border x:Name="LogBorder" Background="#E6070A12" BorderBrush="{StaticResource White10Brush}" BorderThickness="0,1,0,0" Padding="8" Visibility="Collapsed" VerticalAlignment="Bottom" Height="110">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="CONSOLE LOG" FontFamily="{StaticResource GeistMono}" FontSize="9" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,0,0,3"/>
                                    <TextBox Grid.Row="1" x:Name="LogTextBox" Background="Transparent" Foreground="{StaticResource PrimaryBrush}" BorderThickness="0" FontFamily="Consolas" FontSize="10" IsReadOnly="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" CaretBrush="{StaticResource PrimaryBrush}"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Bottom Row: Scene Strip -->
                <Border Grid.Row="2" Background="{StaticResource SurfaceContainerBrush}" BorderBrush="{StaticResource White10Brush}" BorderThickness="0,1,0,0">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" WindowChrome.IsHitTestVisibleInChrome="True">
                        <StackPanel Orientation="Horizontal" Margin="10,0" VerticalAlignment="Center">

                            <!-- Scene 1 -->
                            <StackPanel Margin="0,0,8,0" VerticalAlignment="Center">
                                <Border x:Name="Scene1Thumb" Style="{StaticResource SceneCardStyle}" Background="{StaticResource SurfaceHighestBrush}" BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="2" MouseDown="SceneThumb_Click">
                                    <Grid>
                                        <TextBlock Text="📹" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <Border Background="{StaticResource PrimaryBrush}" CornerRadius="2" Padding="3,1" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="2">
                                            <TextBlock Text="ACTIVO" FontFamily="{StaticResource GeistMono}" FontSize="7" FontWeight="Bold" Foreground="{StaticResource OnPrimaryBrush}"/>
                                        </Border>
                                    </Grid>
                                </Border>
                                <TextBlock Text="Escena 1" FontFamily="{StaticResource GeistMono}" FontSize="9" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                            </StackPanel>

                            <!-- Scene 2 -->
                            <StackPanel Margin="0,0,8,0" VerticalAlignment="Center">
                                <Border x:Name="Scene2Thumb" Style="{StaticResource SceneCardStyle}" Background="{StaticResource SurfaceHighestBrush}" MouseDown="SceneThumb_Click" Opacity="0.7">
                                    <TextBlock Text="🎤" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Entrevista" FontFamily="{StaticResource GeistMono}" FontSize="9" Foreground="{StaticResource OnSurfaceVariantBrush}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                            </StackPanel>

                            <!-- Scene 3 -->
                            <StackPanel Margin="0,0,8,0" VerticalAlignment="Center">
                                <Border x:Name="Scene3Thumb" Style="{StaticResource SceneCardStyle}" Background="{StaticResource SurfaceHighestBrush}" MouseDown="SceneThumb_Click" Opacity="0.7">
                                    <TextBlock Text="🖥️" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Pantalla" FontFamily="{StaticResource GeistMono}" FontSize="9" Foreground="{StaticResource OnSurfaceVariantBrush}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                            </StackPanel>

                            <!-- Add Scene Button -->
                            <StackPanel Margin="0,0,8,0" VerticalAlignment="Center">
                                <Border Style="{StaticResource SceneCardStyle}" Background="Transparent" BorderBrush="{StaticResource White10Brush}" BorderThickness="1" Cursor="Hand">
                                    <TextBlock Text="+" FontSize="20" Foreground="{StaticResource OnSurfaceVariantBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Nueva" FontFamily="{StaticResource GeistMono}" FontSize="9" Foreground="{StaticResource OnSurfaceVariantBrush}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- ─────────────────────────────────────────────────────────────── -->
            <!-- RIGHT COLUMN: PROPERTIES & TELEMETRY -->
            <!-- ─────────────────────────────────────────────────────────────── -->
            <Border Grid.Column="2" Background="{StaticResource SurfaceDimBrush}" BorderBrush="{StaticResource White10Brush}" BorderThickness="1,0,0,0">
                <ScrollViewer Padding="10,10,14,10" VerticalScrollBarVisibility="Auto" WindowChrome.IsHitTestVisibleInChrome="True">
                    <StackPanel>

                        <!-- Header Source -->
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <TextBlock Text="PROPIEDADES" Style="{StaticResource MonoLabel}" Margin="0,0,0,6"/>
                                <Border Background="{StaticResource SurfaceContainerBrush}" CornerRadius="6" Padding="8" BorderBrush="#3355EE71" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="#1A55EE71" CornerRadius="5" Padding="5" Margin="0,0,8,0" VerticalAlignment="Center">
                                            <TextBlock Text="🎥" FontSize="13"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="iPhone Camera" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource OnSurfaceBrush}"/>
                                            <TextBlock Text="FUENTE USB NATIVA" FontFamily="{StaticResource GeistMono}" FontSize="8" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Transform Summary -->
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <TextBlock Text="RESUMEN DE TRANSFORMACIÓN" Style="{StaticResource MonoLabel}" Margin="0,0,0,6"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,4,6">
                                        <TextBlock Text="ZOOM" FontSize="9" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                                        <TextBlock x:Name="PropZoom" Text="1.0x" FontFamily="{StaticResource GeistMono}" FontSize="10" Foreground="{StaticResource PrimaryBrush}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,6">
                                        <TextBlock Text="ESPEJO" FontSize="9" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                                        <TextBlock x:Name="PropMirror" Text="OFF" FontFamily="{StaticResource GeistMono}" FontSize="10" Foreground="{StaticResource PrimaryBrush}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,4,0">
                                        <TextBlock Text="ROTACIÓN" FontSize="9" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                                        <TextBlock x:Name="PropRotation" Text="0°" FontFamily="{StaticResource GeistMono}" FontSize="10" Foreground="{StaticResource PrimaryBrush}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="1">
                                        <TextBlock Text="FILTRO" FontSize="9" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                                        <TextBlock x:Name="PropFilter" Text="Ninguno" FontFamily="{StaticResource GeistMono}" FontSize="10" Foreground="{StaticResource PrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Telemetry -->
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <TextBlock Text="TELEMETRÍA EN TIEMPO REAL" Style="{StaticResource MonoLabel}" Margin="0,0,0,6"/>

                                <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="BITRATE" FontFamily="{StaticResource GeistMono}" FontSize="9" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                                    <TextBlock Grid.Column="1" x:Name="BitrateText" Text="0.0 Mbps" FontFamily="{StaticResource GeistMono}" FontSize="10" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                                </Grid>

                                <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="LATENCIA" FontFamily="{StaticResource GeistMono}" FontSize="9" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                                    <TextBlock Grid.Column="1" x:Name="LatencyText" Text="0ms" FontFamily="{StaticResource GeistMono}" FontSize="10" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                                </Grid>

                                <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="FPS VÍA USB" FontFamily="{StaticResource GeistMono}" FontSize="9" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                                    <TextBlock Grid.Column="1" x:Name="FpsText" Text="30" FontFamily="{StaticResource GeistMono}" FontSize="10" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="RESOLUCIÓN" FontFamily="{StaticResource GeistMono}" FontSize="9" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                                    <TextBlock Grid.Column="1" x:Name="ResolutionText" Text="1080p" FontFamily="{StaticResource GeistMono}" FontSize="10" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Battery -->
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <TextBlock Text="BATERÍA DEL IPHONE" Style="{StaticResource MonoLabel}" Margin="0,0,0,6"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Height="8" Background="{StaticResource SurfaceHighestBrush}" CornerRadius="4" Margin="0,0,8,0" VerticalAlignment="Center">
                                        <Border x:Name="BatteryBarFill" Height="8" Background="{StaticResource PrimaryBrush}" CornerRadius="4" HorizontalAlignment="Stretch"/>
                                    </Border>

                                    <TextBlock Grid.Column="1" x:Name="BatteryText" Text="100%" FontFamily="{StaticResource GeistMono}" FontSize="10" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Manual Focus & Brightness -->
                        <Border Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <TextBlock Text="ENFOQUE Y BRILLO" Style="{StaticResource MonoLabel}" Margin="0,0,0,6"/>

                                <CheckBox x:Name="AutofocusCheckBox" Content="Enfoque Automático" Checked="FocusControl_Changed" Unchecked="FocusControl_Changed" Margin="0,0,0,5" IsChecked="True"/>
                                <Slider x:Name="FocusSlider" Minimum="0.0" Maximum="1.0" Value="0.5" IsEnabled="False" Margin="0,0,0,3" ValueChanged="FocusControl_Changed"/>
                                <TextBlock Text="Foco Manual" FontSize="10" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,0,0,8"/>

                                <Border Height="1" Background="{StaticResource White05Brush}" Margin="0,0,0,8"/>

                                <Grid Margin="0,0,0,1">
                                    <TextBlock Text="Brillo de Exposición" FontSize="10" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                                    <TextBlock x:Name="BrightnessValueText" Text="0.0" FontFamily="{StaticResource GeistMono}" FontSize="10" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Right"/>
                                </Grid>
                                <Slider x:Name="BrightnessSlider" Minimum="-2.0" Maximum="2.0" Value="0.0" SmallChange="0.1" ValueChanged="BrightnessSlider_ValueChanged"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- ROW 3: FOOTER METRICS BAR -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="3" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource White10Brush}" BorderThickness="0,1,0,0" Padding="14,0">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="CPU:" FontFamily="{StaticResource GeistMono}" FontSize="9" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                    <TextBlock Text="12%" FontFamily="{StaticResource GeistMono}" FontSize="9" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,14,0" VerticalAlignment="Center"/>

                    <TextBlock Text="RAM:" FontFamily="{StaticResource GeistMono}" FontSize="9" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                    <TextBlock Text="450MB" FontFamily="{StaticResource GeistMono}" FontSize="9" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,14,0" VerticalAlignment="Center"/>

                    <TextBlock Text="STREAM:" FontFamily="{StaticResource GeistMono}" FontSize="9" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                    <TextBlock Text="1080p 30FPS" FontFamily="{StaticResource GeistMono}" FontSize="9" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,14,0" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock Text="✓" FontSize="11" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                    <TextBlock Text="SISTEMA ESTABLE (USB)" FontFamily="{StaticResource GeistMono}" FontSize="9" Foreground="{StaticResource OnSurfaceVariantBrush}" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
