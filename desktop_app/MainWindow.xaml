<Window x:Class="desktop_app.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Antigravity Camo Studio" Height="680" Width="1120"
        Background="#0b0f19" Foreground="#f8fafc"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header (Camo Studio Look) -->
        <Border Grid.Row="0" Margin="0,0,0,20" Padding="0,0,0,15" BorderThickness="0,0,0,1" BorderBrush="#1e293b">
            <Grid>
                <StackPanel HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Antigravity" FontSize="26" FontWeight="ExtraBold" Foreground="#38bdf8"/>
                        <TextBlock Text=" Camo" FontSize="26" FontWeight="Light" Foreground="#818cf8" Margin="5,0,0,0"/>
                    </StackPanel>
                    <TextBlock Text="Estación de Trabajo y Receptor Virtual de Alta Fidelidad" FontSize="11" Foreground="#64748b" Margin="0,2,0,0"/>
                </StackPanel>
                
                <!-- Status Badge -->
                <Border x:Name="StatusBadge" HorizontalAlignment="Right" VerticalAlignment="Center" 
                        Background="#1e1b4b" BorderThickness="1" BorderBrush="#312e81" CornerRadius="15" Padding="12,5">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="StatusIndicatorDot" Width="8" Height="8" Fill="#ef4444" Margin="0,0,8,0"/>
                        <TextBlock x:Name="StatusBadgeText" Text="SIN SEÑAL" FontSize="11" FontWeight="Bold" Foreground="#818cf8"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Main Workspace -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- Column 0: Controls & Connection -->
            <Grid Grid.Column="0" Margin="0,0,20,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <StackPanel Grid.Row="0">
                    <!-- Device Status Panel -->
                    <Border Background="#111827" BorderThickness="1" BorderBrush="#1f2937" CornerRadius="16" Padding="18" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="CONEXIÓN USB" FontSize="11" FontWeight="Bold" Foreground="#64748b" Margin="0,0,0,10"/>
                            
                            <Grid Margin="0,5">
                                <TextBlock Text="iPhone:" Foreground="#94a3b8" VerticalAlignment="Center"/>
                                <TextBlock x:Name="DeviceStatusText" Text="Desconectado" FontSize="14" FontWeight="Bold" Foreground="#ef4444" HorizontalAlignment="Right"/>
                            </Grid>
                            
                            <TextBlock x:Name="DeviceDetailsText" Text="Por favor, conecta tu iPhone mediante un cable USB." 
                                       FontSize="11" Foreground="#64748b" TextWrapping="Wrap" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Stream Configuration -->
                    <Border Background="#111827" BorderThickness="1" BorderBrush="#1f2937" CornerRadius="16" Padding="18">
                        <StackPanel>
                            <TextBlock Text="CONFIGURACIÓN DE RED" FontSize="11" FontWeight="Bold" Foreground="#64748b" Margin="0,0,0,12"/>
                            
                            <Grid Margin="0,6">
                                <TextBlock Text="Puerto del Túnel:" Foreground="#94a3b8"/>
                                <TextBlock Text="6000 (TCP)" Foreground="#f8fafc" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Margin="0,6">
                                <TextBlock Text="Resolución:" Foreground="#94a3b8"/>
                                <TextBlock Text="1280x720 (HD)" Foreground="#f8fafc" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Margin="0,6">
                                <TextBlock Text="FPS Máximos:" Foreground="#94a3b8"/>
                                <TextBlock Text="60 FPS" Foreground="#4ade80" FontWeight="Bold" HorizontalAlignment="Right"/>
                            </Grid>

                            <Button x:Name="StartTunnelBtn" Content="Iniciar Servidor USB" Background="#4f46e5" BorderThickness="0" 
                                    Foreground="White" FontSize="12" FontWeight="Bold" Padding="12" Margin="0,20,0,0" Click="StartTunnelBtn_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="10"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
                
                <!-- Quick Tips Card -->
                <Border Grid.Row="1" Background="#0f172a" BorderThickness="1" BorderBrush="#1e293b" CornerRadius="16" Padding="18" Margin="0,15,0,0" VerticalAlignment="Bottom">
                    <StackPanel>
                        <TextBlock Text="CONSEJO DE LATENCIA" FontSize="11" FontWeight="Bold" Foreground="#818cf8" Margin="0,0,0,5"/>
                        <TextBlock Text="Usa cables USB-C o Lightning certificados de alta velocidad para lograr la menor latencia posible (&lt; 50ms)." 
                                   FontSize="11" Foreground="#94a3b8" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Column 1: Live Studio Preview (The center element) -->
            <Border Grid.Column="1" Background="#020617" BorderThickness="1" BorderBrush="#312e81" CornerRadius="20" Padding="3" ClipToBounds="True">
                <Grid>
                    <!-- Background Grid -->
                    <Grid.Background>
                        <VisualBrush TileMode="Tile" Viewport="0,0,20,20" ViewportUnits="Absolute">
                            <VisualBrush.Visual>
                                <Grid Width="20" Height="20">
                                    <Rectangle Fill="#020617"/>
                                    <Path Data="M 0,0 L 20,20 M 20,0 L 0,20" Stroke="#0b0f19" StrokeThickness="0.5"/>
                                </Grid>
                            </VisualBrush.Visual>
                        </VisualBrush>
                    </Grid.Background>

                    <!-- Realtime Video Display -->
                    <Border CornerRadius="17" ClipToBounds="True">
                        <Image x:Name="VideoPreviewImage" Stretch="Uniform" RenderOptions.BitmapScalingMode="Linear"/>
                    </Border>

                    <!-- Placeholder: Displayed when not streaming -->
                    <Grid x:Name="PlaceholderGrid" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Border Width="64" Height="64" Background="#1e1b4b" CornerRadius="32" BorderThickness="1" BorderBrush="#312e81" Margin="0,0,0,15">
                                <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.53c-.26-.81-1-1.4-1.9-1.4h-1v-3c0-.55-.45-1-1-1h-6v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.4z" 
                                      Fill="#818cf8" Width="32" Height="32" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Camo Live Preview" FontSize="16" FontWeight="Bold" Foreground="#f8fafc" HorizontalAlignment="Center"/>
                            <TextBlock Text="Esperando el stream de video de tu iPhone..." FontSize="12" Foreground="#64748b" Margin="0,5,0,0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- Column 2: Console Log -->
            <Border Grid.Column="2" Margin="20,0,0,0" Background="#090d16" BorderThickness="1" BorderBrush="#1e293b" CornerRadius="16" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="REGISTRO DE DIAGNÓSTICO" FontSize="11" FontWeight="Bold" Foreground="#64748b" Margin="5,0,0,8"/>
                    
                    <TextBox Grid.Row="1" x:Name="LogTextBox" Background="Transparent" Foreground="#38bdf8" BorderThickness="0" 
                             FontFamily="Consolas" FontSize="11" IsReadOnly="True" VerticalScrollBarVisibility="Auto" 
                             TextWrapping="Wrap" Margin="0,5,0,0" CaretBrush="#38bdf8"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Footer -->
        <TextBlock Grid.Row="2" Text="Antigravity Camo Receiver v2.0 • Procesamiento H.264 por Hardware de Ultra Baja Latencia" 
                   FontSize="10" Foreground="#475569" HorizontalAlignment="Center" Margin="0,15,0,0"/>
    </Grid>
</Window>
