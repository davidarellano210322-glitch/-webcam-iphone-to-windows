<Window x:Class="desktop_app.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Antigravity Camo Studio Pro" Height="760" Width="1280"
        Background="#080c14" Foreground="#f8fafc"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <!-- Accent Color Palette -->
        <SolidColorBrush x:Key="AccentColorBrush" Color="#e11d48"/>
        <SolidColorBrush x:Key="SidebarBgBrush" Color="#0e131f"/>
        <SolidColorBrush x:Key="CardBgBrush" Color="#161b26"/>
        <SolidColorBrush x:Key="ControlBgBrush" Color="#1f2430"/>
        <SolidColorBrush x:Key="BorderColorBrush" Color="#2e3547"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#64748b"/>
        
        <!-- Flat ScrollViewer style -->
        <Style TargetType="ScrollViewer">
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <!-- Slider custom styling -->
        <Style TargetType="Slider">
            <Setter Property="Background" Value="#1f2430"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Background="Transparent">
                            <Border Height="4" Background="#1f2430" CornerRadius="2" VerticalAlignment="Center"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}" Background="#e11d48" BorderThickness="0" Height="4" VerticalAlignment="Center">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="14" Height="14">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Fill="#e11d48" Stroke="#161b26" StrokeThickness="2" Width="14" Height="14"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Flat CheckBox custom template -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#f8fafc"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <BulletDecorator Background="Transparent">
                            <BulletDecorator.Bullet>
                                <Grid Width="16" Height="16" SnapsToDevicePixels="True">
                                    <Border x:Name="border" Background="#1f2430" BorderBrush="#2e3547" BorderThickness="1" CornerRadius="4"/>
                                    <Path x:Name="checkMark" Data="M1,4 L3,6 L7,2" Stroke="#f8fafc" StrokeThickness="2" 
                                          SnapsToDevicePixels="True" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </BulletDecorator.Bullet>
                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Left" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </BulletDecorator>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#e11d48"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#e11d48"/>
                                <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ToggleButton Mode styling -->
        <Style x:Key="ModeToggleButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#64748b"/>
            <Setter Property="Width" Value="55"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="#1f2430"/>
                                <Setter Property="Foreground" Value="#e11d48"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#e11d48"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- ComboBox ToggleButton template -->
        <ControlTemplate x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
            <Border x:Name="Border" Background="#161b26" BorderBrush="#2e3547" BorderThickness="1" CornerRadius="6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="30" />
                    </Grid.ColumnDefinitions>
                    <Path Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Fill="#64748b" Data="M 0 0 L 4 4 L 8 0 Z"/>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="true">
                    <Setter TargetName="Border" Property="BorderBrush" Value="#e11d48"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="true">
                    <Setter TargetName="Border" Property="BorderBrush" Value="#e11d48"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- ComboBox Style -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#161b26"/>
            <Setter Property="Foreground" Value="#f8fafc"/>
            <Setter Property="BorderBrush" Value="#2e3547"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="true"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Name="ToggleButton" 
                                          Template="{StaticResource ComboBoxToggleButton}" 
                                          Focusable="false"
                                          IsChecked="{Binding Path=IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}" 
                                          ClickMode="Press"/>
                            <ContentPresenter Name="ContentSite" 
                                              IsHitTestVisible="False" 
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="10,3,30,3"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left" />
                            <Popup Name="Popup" 
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}" 
                                   AllowsTransparency="True" 
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid Name="DropDown" 
                                      SnapsToDevicePixels="True" 
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" 
                                            Background="#10141d"
                                            BorderBrush="#2e3547"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Margin="0,2,0,0"/>
                                    <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="false">
                                <Setter TargetName="DropDownBorder" Property="MinHeight" Value="95"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBoxItem Style -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#f8fafc"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Border" 
                                Background="{TemplateBinding Background}" 
                                Padding="{TemplateBinding Padding}" 
                                CornerRadius="4"
                                Margin="2,1"
                                SnapsToDevicePixels="true">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="Border" Property="Background" Value="#1f2430"/>
                                <Setter Property="Foreground" Value="#e11d48"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="true">
                                <Setter TargetName="Border" Property="Background" Value="#e11d48"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="25"/>
        </Grid.RowDefinitions>

        <!-- Top Header Bar -->
        <Border Grid.Row="0" Background="#0b0f19" BorderThickness="0,0,0,1" BorderBrush="#1e293b" Padding="15,0">
            <Grid>
                <!-- Title & Version -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Camo Studio Pro" FontSize="16" FontWeight="SemiBold" Foreground="#f8fafc"/>
                    <Border Background="#1e293b" CornerRadius="4" Padding="5,1" Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="v2.0.0" FontSize="10" FontWeight="SemiBold" Foreground="#94a3b8"/>
                    </Border>
                </StackPanel>
                
                <!-- Center Global Controls -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Previsualización:" FontSize="12" Foreground="#94a3b8" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Border CornerRadius="8" Background="#121826" BorderThickness="1" BorderBrush="#1e293b" Padding="8,4">
                        <TextBlock Text="1080p FHD • 60 FPS" FontSize="11" FontWeight="SemiBold" Foreground="#e11d48"/>
                    </Border>
                </StackPanel>

                <!-- Connection status & Tunnel Control -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusIndicatorDot" Width="8" Height="8" Fill="#ef4444" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusBadgeText" Text="SIN SEÑAL" FontSize="11" FontWeight="Bold" Foreground="#ef4444" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    
                    <Button x:Name="StartTunnelBtn" Content="Iniciar Servidor USB" Background="#e11d48" BorderThickness="0" 
                            Foreground="White" FontSize="11" FontWeight="Bold" Padding="12,6" Click="StartTunnelBtn_Click" Visibility="Collapsed">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button x:Name="RecordBtn" Content="Grabar (REC)" Background="#e11d48" BorderThickness="0" 
                            Foreground="White" FontSize="11" FontWeight="Bold" Padding="12,6" Margin="10,0,0,0" Click="RecordBtn_Click" Visibility="Collapsed">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Workplace -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/> <!-- Left Settings -->
                <ColumnDefinition Width="*"/>   <!-- Main Preview Feed -->
                <ColumnDefinition Width="320"/> <!-- Right Enhancements -->
            </Grid.ColumnDefinitions>

            <!-- Column 0: Left Settings Sidebar -->
            <Border Grid.Column="0" Background="#0c101b" BorderThickness="0,0,1,0" BorderBrush="#1e293b">
                <ScrollViewer Padding="12,15">
                    <StackPanel>
                        <!-- Camera settings expander -->
                        <Expander Header="Camera settings" IsExpanded="True" Foreground="#f8fafc" FontWeight="SemiBold" Margin="0,0,0,15">
                            <StackPanel Margin="5,8,5,0">
                                <!-- Device Combobox -->
                                <TextBlock Text="Device" FontSize="10" Foreground="#64748b" Margin="0,0,0,5"/>
                                <ComboBox x:Name="DeviceComboBox" Background="#161b26" Foreground="#f8fafc" BorderBrush="#2e3547" Padding="8,6" Margin="0,0,0,8">
                                    <ComboBoxItem Content="Joe's iPhone" IsSelected="True"/>
                                </ComboBox>
                                
                                <!-- Telemetry details (Battery, charging) -->
                                <Border Background="#161b26" CornerRadius="8" Padding="10,8" Margin="0,0,0,15">
                                    <StackPanel>
                                        <Grid>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                                <TextBlock x:Name="BatteryIcon" Text="🔋" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock x:Name="BatteryPercentageText" Text="91%" FontSize="12" Foreground="#94a3b8" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="USB 3.0" FontSize="11" Foreground="#64748b" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </Grid>
                                        <TextBlock x:Name="DeviceDetailsText" Text="Enchufa tu iPhone por USB" FontSize="10" Foreground="#64748b" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Lens Selector -->
                                <TextBlock Text="Lens" FontSize="10" Foreground="#64748b" Margin="0,0,0,5"/>
                                <ComboBox x:Name="LensComboBox" Background="#161b26" Foreground="#f8fafc" BorderBrush="#2e3547" Padding="8,6" Margin="0,0,0,15" SelectionChanged="LensComboBox_SelectionChanged">
                                    <ComboBoxItem Content="Wide 1.0x (Back)" Tag="wide" IsSelected="True"/>
                                    <ComboBoxItem Content="Ultra Wide 0.5x (Back)" Tag="ultrawide"/>
                                    <ComboBoxItem Content="Telephoto 2.0x (Back)" Tag="telephoto"/>
                                    <ComboBoxItem Content="Selfie Camera (Front)" Tag="front"/>
                                </ComboBox>

                                <!-- Focus Section -->
                                <TextBlock Text="Focus" FontSize="10" Foreground="#64748b" Margin="0,0,0,5"/>
                                <Border Background="#161b26" CornerRadius="8" Padding="10" Margin="0,0,0,15">
                                    <StackPanel>
                                        <CheckBox x:Name="AutofocusCheckBox" Content="Autofocus Continuo" IsChecked="True" Margin="0,0,0,10" Checked="FocusControl_Changed" Unchecked="FocusControl_Changed"/>
                                        <Grid>
                                            <TextBlock Text="Posición:" FontSize="11" Foreground="#64748b" VerticalAlignment="Center"/>
                                            <Slider x:Name="FocusSlider" Minimum="0.0" Maximum="1.0" Value="0.5" Width="170" HorizontalAlignment="Right" ValueChanged="FocusControl_Changed" IsEnabled="False"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Resolution & Frame Rate -->
                                <TextBlock Text="Resolution &amp; frame rate" FontSize="10" Foreground="#64748b" Margin="0,0,0,5"/>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="ResolutionComboBox" Grid.Column="0" Background="#161b26" Foreground="#f8fafc" BorderBrush="#2e3547" Padding="8,6" Margin="0,0,8,0" SelectionChanged="ResolutionComboBox_SelectionChanged">
                                        <ComboBoxItem Content="720p 16:9 (HD)" Tag="720p"/>
                                        <ComboBoxItem Content="1080p 16:9 (FHD)" Tag="1080p" IsSelected="True"/>
                                        <ComboBoxItem Content="4K Ultra HD (2160p)" Tag="4k"/>
                                    </ComboBox>
                                    <ComboBox x:Name="FpsComboBox" Grid.Column="1" Background="#161b26" Foreground="#f8fafc" BorderBrush="#2e3547" Padding="8,6" SelectionChanged="ResolutionComboBox_SelectionChanged">
                                        <ComboBoxItem Content="30 FPS" Tag="30"/>
                                        <ComboBoxItem Content="60 FPS" Tag="60" IsSelected="True"/>
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </Expander>

                        <!-- Audio settings expander -->
                        <Expander Header="Audio settings" IsExpanded="True" Foreground="#f8fafc" FontWeight="SemiBold" Margin="0,0,0,15">
                            <StackPanel Margin="5,8,5,0">
                                <TextBlock Text="Mic" FontSize="10" Foreground="#64748b" Margin="0,0,0,5"/>
                                <ComboBox x:Name="MicComboBox" Background="#161b26" Foreground="#f8fafc" BorderBrush="#2e3547" Padding="8,6" Margin="0,0,0,10">
                                    <ComboBoxItem Content="Camera (Mono)" IsSelected="True"/>
                                    <ComboBoxItem Content="None"/>
                                </ComboBox>
                            </StackPanel>
                        </Expander>

                        <!-- Presets Expander -->
                        <Expander Header="Presets" IsExpanded="False" Foreground="#f8fafc" FontWeight="SemiBold" Margin="0,0,0,15">
                            <StackPanel Margin="5,8,5,0">
                                <ComboBox Background="#161b26" Foreground="#f8fafc" BorderBrush="#2e3547" Padding="8,6" Margin="0,0,0,10">
                                    <ComboBoxItem Content="None" IsSelected="True"/>
                                </ComboBox>
                            </StackPanel>
                        </Expander>

                        <!-- Overlays Expander -->
                        <Expander Header="Overlays" IsExpanded="False" Foreground="#f8fafc" FontWeight="SemiBold" Margin="0,0,0,15">
                            <StackPanel Margin="5,8,5,0">
                                <ComboBox Background="#161b26" Foreground="#f8fafc" BorderBrush="#2e3547" Padding="8,6" Margin="0,0,0,10">
                                    <ComboBoxItem Content="None" IsSelected="True"/>
                                </ComboBox>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>
            </Border>
            <!-- Column 1: Main Stream Feed & Terminal Logs -->
            <Grid Grid.Column="1" Background="#02050b">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Live Feed Frame -->
                <Border Grid.Row="0" Margin="15" Background="#010307" BorderThickness="1" BorderBrush="#1e293b" CornerRadius="12" ClipToBounds="True">
                    <Grid>
                        <!-- Checkerboard visual background -->
                        <Grid.Background>
                            <VisualBrush TileMode="Tile" Viewport="0,0,20,20" ViewportUnits="Absolute">
                                <VisualBrush.Visual>
                                    <Grid Width="20" Height="20">
                                        <Rectangle Fill="#010307"/>
                                        <Path Data="M 0,0 L 20,20 M 20,0 L 0,20" Stroke="#0b0f19" StrokeThickness="0.5"/>
                                    </Grid>
                                </VisualBrush.Visual>
                            </VisualBrush>
                        </Grid.Background>

                        <!-- Video Display (WriteableBitmap) -->
                        <Image x:Name="VideoPreviewImage" Stretch="Uniform" RenderOptions.BitmapScalingMode="Linear"/>

                        <!-- Not Connected Overlay -->
                        <Grid x:Name="PlaceholderGrid" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Border Width="56" Height="56" Background="#111827" CornerRadius="28" BorderThickness="1" BorderBrush="#1e293b" Margin="0,0,0,12">
                                    <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.53c-.26-.81-1-1.4-1.9-1.4h-1v-3c0-.55-.45-1-1-1h-6v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.4z" 
                                          Fill="#e11d48" Width="26" Height="26" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Camo Studio Live Stream" FontSize="14" FontWeight="Bold" Foreground="#f8fafc" HorizontalAlignment="Center"/>
                                <TextBlock Text="Conecta el iPhone por USB y haz clic en Iniciar Servidor." FontSize="11" Foreground="#64748b" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Diagnostic Terminal Console logs -->
                <Border x:Name="LogBorder" Grid.Row="1" Background="#070a12" BorderThickness="0,1,0,0" BorderBrush="#1e293b" Padding="12" Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="CONSOLE DIAGNOSTICS LOG" FontSize="10" FontWeight="Bold" Foreground="#64748b" Margin="0,0,0,5"/>
                        <TextBox Grid.Row="1" x:Name="LogTextBox" Background="Transparent" Foreground="#f43f5e" BorderThickness="0" 
                                 FontFamily="Consolas" FontSize="10" IsReadOnly="True" VerticalScrollBarVisibility="Auto" 
                                 TextWrapping="Wrap" CaretBrush="#e11d48" Height="120"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Column 2: Right Adjustments Sidebar -->
            <Border Grid.Column="2" Background="#0c101b" BorderThickness="1,0,0,0" BorderBrush="#1e293b">
                <ScrollViewer Padding="12,15">
                    <StackPanel>
                        <!-- Image enhancements expander -->
                        <Expander Header="Image enhancements" IsExpanded="True" Foreground="#f8fafc" FontWeight="SemiBold" Margin="0,0,0,15">
                            <StackPanel Margin="5,8,5,0">
                                <!-- Mode selection (Icons replica) -->
                                <TextBlock Text="Mode" FontSize="10" Foreground="#64748b" Margin="0,0,0,5"/>
                                <Border Background="#161b26" CornerRadius="8" Padding="5" Margin="0,0,0,12">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <RadioButton Content="Normal" Style="{StaticResource ModeToggleButtonStyle}" IsChecked="True"/>
                                        <RadioButton Content="Blur" Style="{StaticResource ModeToggleButtonStyle}" Margin="10,0"/>
                                        <RadioButton Content="Spot" Style="{StaticResource ModeToggleButtonStyle}"/>
                                    </StackPanel>
                                </Border>

                                <!-- Spotlight controls -->
                                <CheckBox x:Name="SpotlightCheckBox" Content="Spotlight Face Tracking" Margin="0,0,0,6" Checked="SpotlightCheckBox_Changed" Unchecked="SpotlightCheckBox_Changed"/>
                                <Grid Margin="0,0,0,15">
                                    <TextBlock Text="Intensidad:" FontSize="11" Foreground="#64748b" VerticalAlignment="Center"/>
                                    <Slider x:Name="SpotlightSlider" Minimum="0" Maximum="100" Value="48" Width="170" HorizontalAlignment="Right" ValueChanged="SpotlightSlider_ValueChanged"/>
                                </Grid>

                                <!-- Auto Framing controls -->
                                <CheckBox x:Name="AutoFramingCheckBox" Content="Auto Framing (Seguimiento)" Margin="0,0,0,6" Checked="AutoFramingControl_Changed" Unchecked="AutoFramingControl_Changed"/>
                                <CheckBox x:Name="AutoFramingZoomCheckBox" Content="Auto Framing + Zoom Inteligente" Margin="0,0,0,15" Checked="AutoFramingControl_Changed" Unchecked="AutoFramingControl_Changed" IsEnabled="False"/>

                                <!-- Filters -->
                                <TextBlock Text="Filter" FontSize="10" Foreground="#64748b" Margin="0,0,0,5"/>
                                <ComboBox x:Name="FilterComboBox" Background="#161b26" Foreground="#f8fafc" BorderBrush="#2e3547" Padding="8,6" Margin="0,0,0,12" SelectionChanged="FilterComboBox_SelectionChanged">
                                    <ComboBoxItem Content="None" Tag="none" IsSelected="True"/>
                                    <ComboBoxItem Content="Monocromo" Tag="mono"/>
                                    <ComboBoxItem Content="Sepia" Tag="sepia"/>
                                    <ComboBoxItem Content="Negativo" Tag="negative"/>
                                    <ComboBoxItem Content="Vintage (Warm)" Tag="vintage"/>
                                    <ComboBoxItem Content="Cool Blue" Tag="cool"/>
                                </ComboBox>

                                <!-- Filter Intensity slider -->
                                <TextBlock Text="Intensidad de Filtro" FontSize="10" Foreground="#64748b" Margin="0,0,0,5"/>
                                <Grid Margin="0,0,0,12">
                                    <Slider x:Name="FilterIntensitySlider" Minimum="0" Maximum="100" Value="100" SmallChange="5" ValueChanged="FilterIntensitySlider_ValueChanged"/>
                                </Grid>

                                <!-- AR settings -->
                                <TextBlock Text="AR Video" FontSize="10" Foreground="#64748b" Margin="0,0,0,5"/>
                                <ComboBox x:Name="ArComboBox" Background="#161b26" Foreground="#f8fafc" BorderBrush="#2e3547" Padding="8,6" Margin="0,0,0,10">
                                    <ComboBoxItem Content="Normal" IsSelected="True"/>
                                    <ComboBoxItem Content="Zoom Fit"/>
                                </ComboBox>

                                <!-- Mirror & Rotation -->
                                <TextBlock Text="Transformaciones" FontSize="10" Foreground="#64748b" Margin="0,0,0,5"/>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox x:Name="MirrorCheckBox" Content="Espejo" Grid.Column="0" VerticalAlignment="Center" Checked="TransformControl_Changed" Unchecked="TransformControl_Changed"/>
                                    <ComboBox x:Name="RotationComboBox" Grid.Column="1" Background="#161b26" Foreground="#f8fafc" BorderBrush="#2e3547" Padding="5,3" SelectionChanged="TransformControl_Changed">
                                        <ComboBoxItem Content="Rotación: 0°" Tag="0" IsSelected="True"/>
                                        <ComboBoxItem Content="Rotación: 90°" Tag="90"/>
                                        <ComboBoxItem Content="Rotación: 180°" Tag="180"/>
                                        <ComboBoxItem Content="Rotación: 270°" Tag="270"/>
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </Expander>

                        <!-- Image adjustments expander -->
                        <Expander Header="Image adjustments" IsExpanded="True" Foreground="#f8fafc" FontWeight="SemiBold" Margin="0,0,0,15">
                            <StackPanel Margin="5,8,5,0">
                                <!-- Exposure settings -->
                                <CheckBox x:Name="ExposureCheckBox" Content="Custom Exposure" Margin="0,0,0,6" Checked="ExposureControl_Changed" Unchecked="ExposureControl_Changed"/>
                                <Grid Margin="0,0,0,6">
                                    <TextBlock Text="Velocidad (ms):" FontSize="11" Foreground="#64748b" VerticalAlignment="Center"/>
                                    <Slider x:Name="ShutterSlider" Minimum="1" Maximum="200" Value="33" Width="170" HorizontalAlignment="Right" IsEnabled="False" ValueChanged="ExposureControl_Changed"/>
                                </Grid>
                                <Grid Margin="0,0,0,15">
                                    <TextBlock Text="ISO Gain:" FontSize="11" Foreground="#64748b" VerticalAlignment="Center"/>
                                    <Slider x:Name="IsoSlider" Minimum="50" Maximum="1600" Value="300" Width="170" HorizontalAlignment="Right" IsEnabled="False" ValueChanged="ExposureControl_Changed"/>
                                </Grid>

                                <!-- White Balance -->
                                <CheckBox x:Name="WhiteBalanceCheckBox" Content="White Balance" Margin="0,0,0,6" Checked="WhiteBalanceControl_Changed" Unchecked="WhiteBalanceControl_Changed"/>
                                <Grid Margin="0,0,0,6">
                                    <TextBlock Text="Temp:" FontSize="11" Foreground="#64748b" VerticalAlignment="Center"/>
                                    <Slider x:Name="TemperatureSlider" Minimum="2000" Maximum="8000" Value="5000" Width="170" HorizontalAlignment="Right" IsEnabled="False" ValueChanged="WhiteBalanceControl_Changed"/>
                                </Grid>
                                <Grid Margin="0,0,0,15">
                                    <TextBlock Text="Matiz (Tint):" FontSize="11" Foreground="#64748b" VerticalAlignment="Center"/>
                                    <Slider x:Name="TintSlider" Minimum="-150" Maximum="150" Value="0" Width="170" HorizontalAlignment="Right" IsEnabled="False" ValueChanged="WhiteBalanceControl_Changed"/>
                                </Grid>

                                <!-- Flash level / Torch control -->
                                <Grid Margin="0,0,0,10">
                                    <CheckBox x:Name="TorchCheckBox" Content="Linterna (Torch)" Checked="TorchControl_Changed" Unchecked="TorchControl_Changed" VerticalAlignment="Center"/>
                                </Grid>

                                <!-- Brightness slider -->
                                <TextBlock Text="Brightness" FontSize="10" Foreground="#64748b" Margin="0,0,0,5"/>
                                <Grid Margin="0,0,0,10">
                                    <Slider x:Name="BrightnessSlider" Minimum="-2.0" Maximum="2.0" Value="0.0" SmallChange="0.1" ValueChanged="BrightnessSlider_ValueChanged"/>
                                </Grid>

                                <!-- Zoom slider -->
                                <TextBlock Text="Zoom Digital" FontSize="10" Foreground="#64748b" Margin="0,0,0,5"/>
                                <Grid Margin="0,0,0,10">
                                    <Slider x:Name="ZoomSlider" Minimum="1.0" Maximum="5.0" Value="1.0" SmallChange="0.1" ValueChanged="ZoomSlider_ValueChanged"/>
                                </Grid>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
        <!-- Footer Bar -->
        <Border Grid.Row="2" Background="#0b0f19" BorderThickness="0,1,0,0" BorderBrush="#1e293b" Padding="15,0">
            <Grid>
                <TextBlock Text="Antigravity Camo Receiver v2.0 • Ultra-Low Latency USB Tunneling Active" 
                           FontSize="10" Foreground="#475569" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <CheckBox x:Name="ShowLogsCheckBox" Content="Ver Logs Diagnósticos" Foreground="#475569" FontSize="10" VerticalAlignment="Center" Margin="0,0,15,0" Checked="ShowLogsCheckBox_Changed" Unchecked="ShowLogsCheckBox_Changed"/>
                    <TextBlock Text="DirectShow Virtual Camera Ready" FontSize="10" Foreground="#475569" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
