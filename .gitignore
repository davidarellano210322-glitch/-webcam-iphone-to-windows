# dotnet (C#)
**/bin/
**/obj/
**/.vs/
**/*.user
**/*.suo

# Flutter / Dart
**/build/
**/.dart_tool/
**/.flutter-plugins
**/.flutter-plugins-dependencies
**/.pub-cache/
**/.pub/
**/mobile_app/ios/Flutter/Generated.xcconfig
**/mobile_app/ios/Flutter/flutter_export_environment.sh

# IDEs and OS files
.idea/
.vscode/
*.iml
.DS_Store
Thumbs.db

# Temporary test folders
/test_api/

# Local-only artifacts (binaries, installers, archives, legacy code).
# Keep these on disk but never commit them.
/_local/

# Python cache
__pycache__/
*.pyc

# Secrets / certificates (never commit private keys or self-signed certs)
*.pem
*.key
*.p12
*.pfx

# Large binaries / build artifacts
*.ipa
*.zip
vs_BuildTools.exe
vs_community.exe
